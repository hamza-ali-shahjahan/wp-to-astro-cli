    <item>
        <title>Mixed content</title>
        <link>https://example.com/rich-content/</link>
        <pubDate>Mon, 01 Apr 2024 10:00:00 +0000</pubDate>
        <dc:creator><![CDATA[admin]]></dc:creator>
        <guid isPermaLink="false">https://example.com/?p=10</guid>
        <description></description>
        <content:encoded><![CDATA[<!-- wp:heading -->
<h2>Mixed content</h2>
<!-- /wp:heading -->

<!-- wp:list -->
<ul class="wp-block-list"><!-- wp:list-item -->
<li>First item</li>
<!-- /wp:list-item -->

<!-- wp:list-item -->
<li>Second item</li>
<!-- /wp:list-item --></ul>
<!-- /wp:list -->

<!-- wp:quote -->
<blockquote class="wp-block-quote"><p>The best way out is always through.</p><cite>Robert Frost</cite></blockquote>
<!-- /wp:quote -->

<!-- wp:code -->
<pre class="wp-block-code"><code>const greeting = &quot;hello&quot;;</code></pre>
<!-- /wp:code -->

<!-- wp:separator -->
<hr class="wp-block-separator has-alpha-channel-opacity"/>
<!-- /wp:separator -->

<!-- wp:paragraph -->
<p>Closing thought.</p>
<!-- /wp:paragraph -->]]></content:encoded>
