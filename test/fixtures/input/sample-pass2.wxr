        <content:encoded><![CDATA[<!-- wp:paragraph -->
<p>Steps to make tea:</p>
<!-- /wp:paragraph -->

<!-- wp:list {"ordered":true} -->
<ol class="wp-block-list"><!-- wp:list-item -->
<li>Boil water</li>
<!-- /wp:list-item -->

<!-- wp:list-item -->
<li>Add tea bag</li>
<!-- /wp:list-item -->

<!-- wp:list-item -->
<li>Wait three minutes</li>
<!-- /wp:list-item --></ol>
<!-- /wp:list -->

<!-- wp:quote -->
<blockquote class="wp-block-quote"><p>An unattributed quote.</p></blockquote>
<!-- /wp:quote -->]]></content:encoded>
